generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HeroContent {
  id         String   @id @default("singleton")
  heading    String
  subheading String
  ctaText    String
  videoUrl   String?
  updatedAt  DateTime @updatedAt
}

model AboutContent {
  id        String   @id @default("singleton")
  vision    String
  style     String
  trust     String
  updatedAt DateTime @updatedAt
}

model ContactContent {
  id        String   @id @default("singleton")
  email     String
  phone     String?
  whatsapp  String?
  location  String?
  updatedAt DateTime @updatedAt
}

model HiringContent {
  id                  String   @id @default("singleton")
  isVisible           Boolean  @default(false)
  roleTitle           String   @default("")
  profileDescription  String   @default("")
  whoCanApply         String   @default("")
  applyButtonLabel    String   @default("Apply")
  applyUrl            String   @default("")
  updatedAt           DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioItem {
  id          String   @id @default(cuid())
  title       String
  description String
  videoUrl    String?
  posterUrl   String?
  tags        Json?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  fileName  String
  mimeType  String
  alt       String?
  createdAt DateTime @default(now())
}

model TeamMember {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  subtitle    String?
  description String
  photoUrl    String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
